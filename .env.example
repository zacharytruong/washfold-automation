# Pancake POS
PANCAKE_API_KEY=your_api_key
PANCAKE_SHOP_ID=your_shop_id

# Botcake (WhatsApp)
BOTCAKE_ACCESS_TOKEN=your_token
BOTCAKE_PAGE_ID=waba_xxxxx

# Google Sheets
GOOGLE_SHEETS_ID=spreadsheet_id

# Google Service Account (split from JSON to avoid parsing issues)
GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=your-sa@project.iam.gserviceaccount.com
# Base64-encode your private key: echo -n '-----BEGIN PRIVATE KEY-----\n...' | base64
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY_BASE64=base64_encoded_private_key

# Security
WEBHOOK_SECRET=random_secret_for_appsheet
LOG_VIEWER_SECRET=random_secret_for_viewing_log

# Server
PORT=3000
